# LexiCore Backend Configuration
# Copy this file to .env and fill in your actual values

# Groq API Key for AI features (word enrichment, hints, learning insights)
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_actual_key_here_xxxxxxxxxxxx

# Database configuration (optional - defaults to lexicore.db at project root)
# DATABASE_URL=sqlite:///./lexicore.db

# Debug mode (optional - set to False in production)
# DEBUG=True
